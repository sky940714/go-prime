            {/* 帳號輸入 */}
            <View style={styles.inputWrapper}>
              <Mail size={20} color={Colors.stone[400]} />
              <TextInput
                style={styles.input}
                placeholder="電子郵件 / 帳號"
                keyboardType="email-address"
                autoCapitalize="none"
                value={email}
